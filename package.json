{
  "name": "palguide",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "PalGuide — compagnon Palworld 1.0 : Paldex, Breeding, Capture, Team Builder (FR)",
  "author": "PalGuide",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:5180 && cross-env ELECTRON_DEV=1 ELECTRON_RUN_AS_NODE= electron .\"",
    "electron:preview": "npm run build && cross-env ELECTRON_RUN_AS_NODE= electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "build-data": "node scripts/build-data.mjs",
    "scrape-paldb": "node scripts/scrape-paldb.mjs",
    "download-assets": "node scripts/download-assets.mjs",
    "build-map-data": "node scripts/build-map-data.mjs",
    "build-spawns": "node scripts/build-spawns.mjs",
    "build-equipment": "node scripts/build-equipment.mjs",
    "build-schematics": "node scripts/build-schematics.mjs",
    "build-items-catalog": "node scripts/build-items-catalog.mjs"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.460.0",
    "oozextract": "^0.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cheerio": "^1.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.palguide.app",
    "productName": "PalGuide",
    "copyright": "PalGuide — data: PalCalc (MIT), paldb.cc",
    "afterPack": "scripts/afterPack.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png"
    ],
    "asarUnpack": [
      "**/node_modules/oozextract/**"
    ],
    "extraResources": [
      {
        "from": "scripts/import_save.py",
        "to": "import_save.py"
      },
      {
        "from": "scripts/edit_save.py",
        "to": "edit_save.py"
      },
      {
        "from": "scripts/check_pal.py",
        "to": "check_pal.py"
      },
      {
        "from": "scripts/read_inventory.py",
        "to": "read_inventory.py"
      },
      {
        "from": "scripts/fix_host_save.py",
        "to": "fix_host_save.py"
      },
      {
        "from": "scripts/exp_table.json",
        "to": "exp_table.json"
      },
      {
        "from": "scripts/tech_list.json",
        "to": "tech_list.json"
      },
      {
        "from": "scripts/palsav",
        "to": "palsav"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PalGuide"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Game"
    }
  }
}
